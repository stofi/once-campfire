<h1 class="for-screen-reader">Chat Bot Setup</h1>
<label class="align-center center avatar__form gap" data-controller="upload-preview">
  <div class="btn input--file">
    <%= image_tag "camera.svg", aria: { hidden: "true" }, size: 20 %>
    <%= form.file_field :avatar, class: "input", accept: "image/*",
          data: { upload_preview_target: "input", action: "upload-preview#previewImage" } %>
    <span class="for-screen-reader">Upload bot avatar</span>
  </div>

  <div class="avatar input--file txt-xx-large" style="--avatar-size: var(--btn-size);">
    <%= image_tag bot.avatar.attached? ? bot.avatar : "default-bot-avatar.svg", alt: "Bot avatar", size: 48, data: { upload_preview_target: "image" } %>
  </div>
</label>

<div class="flex align-center gap">
  <%= translation_button(:bot_name) %>
  <label class="flex align-center gap flex-item-grow txt-large input input--actor">
    <%= form.text_field :name, class: "input", autocomplete: "name", placeholder: "Name the bot", autofocus: true, required: true,
          data: { "1p-ignore": true } %>
    <%= image_tag "bot.svg", aria: { hidden: "true" }, size: 24, class: "colorize--black" %>
  </label>
</div>

<div class="flex align-center gap">
  <%= translation_button(:webhook_url) %>
  <label class="flex align-center gap flex-item-grow txt-large input input--actor">
    <%= form.url_field :webhook_url, class: "input", placeholder: "Webhook URL" %>
    <%= image_tag "web.svg", aria: { hidden: "true" }, size: 24, class: "colorize--black" %>
  </label>
</div>

<% if @rooms.present? %>
  <div class="flex flex-column gap">
    <h2 class="txt-large margin-none">Room permissions</h2>
    <p class="margin-none txt-small">Select which rooms this bot can read from and write to via the API and webhooks.</p>

    <% @rooms.each do |room| %>
      <% permission = bot.persisted? ? bot.bot_room_permissions.find_by(room_id: room.id) : nil %>
      <div class="flex align-center gap pad-block-half pad-inline border border-radius">
        <strong class="overflow-ellipsis flex-item-grow"><%= room_display_name(room) %></strong>

        <input type="hidden" name="room_permissions[<%= room.id %>][can_read]" value="0">
        <label class="btn txt-small <%= "btn--reversed" if permission&.can_read %>" style="cursor: pointer;" data-controller="perm-toggle">
          <input type="checkbox" name="room_permissions[<%= room.id %>][can_read]" value="1" <%= "checked" if permission&.can_read %> hidden data-action="change->perm-toggle#toggle" data-perm-toggle-target="checkbox">
          Read
        </label>

        <input type="hidden" name="room_permissions[<%= room.id %>][can_write]" value="0">
        <label class="btn txt-small <%= "btn--reversed" if permission&.can_write %>" style="cursor: pointer;" data-controller="perm-toggle">
          <input type="checkbox" name="room_permissions[<%= room.id %>][can_write]" value="1" <%= "checked" if permission&.can_write %> hidden data-action="change->perm-toggle#toggle" data-perm-toggle-target="checkbox">
          Write
        </label>

        <input type="hidden" name="room_permissions[<%= room.id %>][webhook_all_messages]" value="0">
        <label class="btn txt-small <%= "btn--reversed" if permission&.webhook_all_messages %>" style="cursor: pointer;" data-controller="perm-toggle" title="Send webhook for all messages, not just @mentions">
          <input type="checkbox" name="room_permissions[<%= room.id %>][webhook_all_messages]" value="1" <%= "checked" if permission&.webhook_all_messages %> hidden data-action="change->perm-toggle#toggle" data-perm-toggle-target="checkbox">
          All messages
        </label>
      </div>
    <% end %>
  </div>
<% end %>

<%= profile_form_submit_button %>
